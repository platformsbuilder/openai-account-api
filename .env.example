# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/openai-account-api

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h

# Encryption key for API key storage (32 hex chars = 128-bit AES)
ENCRYPTION_KEY=change-this-to-a-32-hex-char-key

# OpenAI
OPENAI_API_URL=https://api.openai.com/v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
